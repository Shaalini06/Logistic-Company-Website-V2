# Environment Variables
# Copy this file to .env.local and update values as needed

# Application
VITE_APP_NAME=FASTER Logistics
VITE_APP_VERSION=1.0.0

# API Configuration (optional)
VITE_API_URL=http://localhost:5000/api

# Contact Email
VITE_CONTACT_EMAIL=info@faster.com
VITE_SUPPORT_EMAIL=support@faster.com

# Google Maps API Key (for contact page map - optional)
VITE_GOOGLE_MAPS_KEY=your_key_here

# Email Service (optional)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_USER_ID=your_user_id

# Analytics (optional)
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
